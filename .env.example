# ============================================================================
# Secrets — NEVER commit real values. Copy to .env and fill in. (.env is gitignored.)
# ============================================================================

# NVIDIA NIM (cloud LLM; OpenAI-compatible). Outbound HTTPS only.
NVIDIA_NIM_API_KEY=replace-me
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct

# ----------------------------------------------------------------------------
# MCP server auth — single shared-secret bearer token required on every call.
# Generate with:  openssl rand -hex 32
# Required by docker-compose (services fail to start if unset).
# ----------------------------------------------------------------------------
MCP_AUTH_TOKEN=replace-with-openssl-rand-hex-32

# ============================================================================
# Host ports — bound to 127.0.0.1 ONLY in docker-compose.yml. Do not expose
# these on 0.0.0.0 / the LAN / the internet. See tasks/PLAN.md §6.1.
# ============================================================================
TELEMETRY_MCP_PORT=8100
RAG_MCP_PORT=8101

# ============================================================================
# Pinned image tags — no :latest. Digest-pin before any non-local exposure.
# Verify these versions exist and suit your needs before first `compose up`.
# ============================================================================
QDRANT_TAG=v1.12.5
OLLAMA_TAG=0.4.0

# ============================================================================
# RAG / embeddings (Ollama, internal network only — not host-published)
# ============================================================================
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_EMBED_MODEL_FALLBACK=nomic-embed-text
QDRANT_COLLECTION=nasa_ntrs
