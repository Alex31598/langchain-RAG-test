# Secrets
.env
*.env
!.env.example

# RAG data (untrusted NASA PDFs) + evaluation reports (may carry injected text)
# Keep the dirs in git via .gitkeep, but ignore all real contents.
projects/rag-mcp/data/*
!projects/rag-mcp/data/.gitkeep
projects/rag-mcp/evaluation/reports/*
!projects/rag-mcp/evaluation/reports/.gitkeep
*.pdf

